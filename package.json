{
  "name": "dmca-redirect",
  "version": "1.5.2",
  "description": "Redirects Google DMCA-blocked searches to Yandex.",
  "main": "background.js",
  "scripts": {
    "lint": "eslint js/*.js",
    "lint:fix": "eslint js/*.js --fix",
    "format": "prettier \"**/*.{js,css,html,json,md}\" --check",
    "format:fix": "prettier \"**/*.{js,css,html,json,md}\" --write",
    "test": "jest",
    "package": "mkdir -p dist && zip -r dist/dmca-redirect.zip manifest.json popup.html css js icon.png",
    "release": "node scripts/release.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiegoFleitas/dmca-redirect.git"
  },
  "author": "Diego",
  "license": "GPL-3.0",
  "devDependencies": {
    "eslint": "^10.3.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3"
  },
  "bugs": {
    "url": "https://github.com/DiegoFleitas/dmca-redirect/issues"
  },
  "homepage": "https://github.com/DiegoFleitas/dmca-redirect#readme"
}
